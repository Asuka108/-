/* 菠萝蓝牙耳机售后AI聊天机器人 - 全局样式 */
/* 采用 Pineapple 设计风格 */

page {
  /* ===== 设计变量 ===== */
  --color-primary: #007AFF;
  --color-primary-dark: #0056CC;
  --color-bg: #F2F2F7;
  --color-card: #FFFFFF;
  --color-text: #1C1C1E;
  --color-text-secondary: #8E8E93;
  --color-separator: #C6C6C8;
  --color-ai-bubble: #F1F1F2;
  --color-user-bubble: #007AFF;
  --color-error: #FF3B30;
  --color-success: #34C759;
  --color-warning: #FF9500;

  /* ===== 圆角 ===== */
  --radius-xs: 4rpx;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;

  /* ===== 字号 ===== */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-title: 40rpx;

  /* ===== 间距 ===== */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* ===== 全局默认 ===== */
  font-family: -pineapple-system, BlinkMacSystemFont, "SF Pro Text",
               "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: var(--font-md);
  color: var(--color-text);
  background-color: var(--color-bg);
  line-height: 1.5;
  box-sizing: border-box;
}

/* ===== 通用工具类 ===== */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 通用按钮 ===== */
.btn-primary {
  background-color: var(--color-primary);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-sm);
  font-size: var(--font-md);
  padding: 16rpx 32rpx;
}

.btn-primary:active {
  background-color: var(--color-primary-dark);
}

.btn-danger {
  background-color: var(--color-error);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-sm);
  font-size: var(--font-md);
  padding: 16rpx 32rpx;
}

/* ===== 通用卡片 ===== */
.card {
  background-color: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin: var(--spacing-sm) var(--spacing-md);
}

/* ===== 通用输入框 ===== */
.input-field {
  height: 72rpx;
  background-color: #FFFFFF;
  border: 1px solid var(--color-separator);
  border-radius: var(--radius-sm);
  padding: 0 var(--spacing-sm);
  font-size: var(--font-md);
  color: var(--color-text);
}

.textarea-field {
  background-color: #FFFFFF;
  border: 1px solid var(--color-separator);
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm);
  font-size: var(--font-md);
  color: var(--color-text);
  min-height: 200rpx;
}

/* ===== 加载动画 ===== */
.loading-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
}

.loading-dots .dot {
  width: 12rpx;
  height: 12rpx;
  background-color: var(--color-text-secondary);
  border-radius: 50%;
  animation: dot-bounce 1.2s infinite ease-in-out;
}

.loading-dots .dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dots .dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dot-bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}
