<!-- 对话历史页 - Pineapple 风格 -->
<view class="history-page">

  <!-- 加载中 -->
  <view class="loading-area" wx:if="{{isLoading}}">
    <view class="loading-dots">
      <view class="dot"></view>
      <view class="dot"></view>
      <view class="dot"></view>
    </view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-area" wx:if="{{!isLoading && conversations.length === 0}}">
    <view class="empty-icon">📋</view>
    <view class="empty-title">暂无对话记录</view>
    <view class="empty-subtitle">去和AI客服聊聊天吧</view>
  </view>

  <!-- 对话列表 -->
  <scroll-view scroll-y class="history-list" wx:if="{{conversations.length > 0}}">
    <view
      wx:for="{{conversations}}"
      wx:key="id"
      class="history-item"
      data-id="{{item.id}}"
      data-title="{{item.title}}"
      bindtap="openConversation"
    >
      <view class="item-left">
        <view class="item-icon">💬</view>
      </view>
      <view class="item-body">
        <view class="item-title text-ellipsis">{{item.title || '未命名对话'}}</view>
        <view class="item-meta">
          <text class="meta-time">最近更新: {{item.updated_at || item.created_at}}</text>
        </view>
      </view>
      <view class="item-arrow">›</view>
    </view>

    <!-- 底部安全距离 -->
    <view style="height: 48rpx;"></view>
  </scroll-view>

</view>
