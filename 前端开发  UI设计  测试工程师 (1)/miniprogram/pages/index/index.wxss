/* 聊天页样式 - Pineapple 风格 */

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F2F2F7;
}

/* ===== 顶部导航 ===== */
.chat-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #FFFFFF;
  border-bottom: 1px solid #E5E5EA;
  padding-top: calc(24rpx + env(safe-area-inset-top));
}

.header-spacer {
  width: 56rpx;
  flex-shrink: 0;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.header-mine {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.header-mine-icon {
  font-size: 36rpx;
}

.header-mine:active {
  opacity: 0.6;
}

/* ===== 消息列表 ===== */
.message-list {
  flex: 1;
  padding: 24rpx 0;
}

/* ===== 欢迎区域 ===== */
.welcome-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx 60rpx;
}

.welcome-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 16rpx;
}

.welcome-subtitle {
  font-size: 28rpx;
  color: #8E8E93;
  margin-bottom: 8rpx;
}

.welcome-tips {
  font-size: 24rpx;
  color: #8E8E93;
  text-align: center;
  line-height: 1.6;
}

/* ===== 消息项 ===== */
.message-item {
  padding: 8rpx 32rpx;
  display: flex;
  flex-direction: column;
}

.msg-user {
  align-items: flex-end;
}

.msg-ai {
  align-items: flex-start;
}

/* ===== 消息气泡 ===== */
.msg-bubble {
  max-width: 72%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  word-break: break-all;
}

.msg-bubble-ai {
  background-color: #F1F1F2;
  border-top-left-radius: 4rpx;
}

.msg-bubble-user {
  background-color: #007AFF;
  border-top-right-radius: 4rpx;
}

.msg-bubble-ai .msg-text {
  color: #1C1C1E;
  font-size: 28rpx;
  line-height: 1.6;
}

.msg-bubble-user .msg-text {
  color: #FFFFFF;
  font-size: 28rpx;
  line-height: 1.6;
}

/* ===== 时间戳 ===== */
.msg-time {
  font-size: 22rpx;
  color: #8E8E93;
  margin-top: 6rpx;
  padding: 0 8rpx;
}

/* ===== 正在输入动画 ===== */
.typing-bubble {
  padding: 16rpx 32rpx;
}

.loading-dots {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.loading-dots .dot {
  width: 14rpx;
  height: 14rpx;
  background-color: #8E8E93;
  border-radius: 50%;
  animation: dot-bounce 1.2s infinite ease-in-out;
}

.loading-dots .dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dots .dot:nth-child(3) {
  animation-delay: 0.4s;
}

/* ===== 错误提示栏 ===== */
.error-bar {
  margin: 0 32rpx 12rpx;
  padding: 20rpx 24rpx;
  background-color: #FFF3F3;
  border: 1px solid #FF3B30;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  color: #FF3B30;
}

.error-bar:active {
  opacity: 0.7;
}

/* ===== 快捷问题横滑栏 ===== */
.quick-bar {
  background-color: #FFFFFF;
  border-top: 1px solid #E5E5EA;
  padding: 16rpx 24rpx;
}

.quick-scroll {
  white-space: nowrap;
  display: flex;
}

.quick-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  background-color: #F2F2F7;
  border: 1px solid #007AFF;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #007AFF;
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.15s;
}

.quick-tag:active {
  background-color: #007AFF;
  color: #FFFFFF;
  transform: scale(0.96);
}

/* ===== 底部输入区域 ===== */
.input-area {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #FFFFFF;
  border-top: 1px solid #E5E5EA;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input-box {
  flex: 1;
  height: 72rpx;
  background-color: #F2F2F7;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #1C1C1E;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  margin-left: 16rpx;
  background-color: #E5E5EA;
  color: #8E8E93;
  border: none;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: all 0.2s;
}

.send-btn-active {
  background-color: #007AFF;
  color: #FFFFFF;
}

.send-btn::after {
  border: none;
}

.send-btn[disabled] {
  background-color: #E5E5EA;
  color: #8E8E93;
}
