.feedback-page {
  min-height: 100vh;
  background-color: #F2F2F7;
  padding: 24rpx;
}

.feedback-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
}

.feedback-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1C1C1E;
  margin-bottom: 16rpx;
  margin-top: 24rpx;
}

.feedback-label:first-child {
  margin-top: 0;
}

.feedback-textarea {
  width: 100%;
  height: 260rpx;
  background-color: #F2F2F7;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #1C1C1E;
  box-sizing: border-box;
}

.feedback-count {
  text-align: right;
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 8rpx;
}

.feedback-input {
  width: 100%;
  height: 72rpx;
  background-color: #F2F2F7;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1C1C1E;
}

.feedback-submit {
  width: 100%;
  height: 88rpx;
  background-color: #007AFF;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 16rpx;
  margin-top: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feedback-submit::after {
  border: none;
}

.feedback-submit:active {
  background-color: #0056CC;
}
