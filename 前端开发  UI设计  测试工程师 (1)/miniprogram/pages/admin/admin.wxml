<!-- 管理员后台 - 知识库管理页 -->
<view class="admin-page">

  <!-- 顶部导航 -->
  <view class="admin-header">
    <view class="header-title">知识库管理</view>
    <view class="header-logout" bindtap="handleLogout">
      <text class="logout-text">退出</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索问题或关键词..."
      placeholder-style="color:#8E8E93"
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
    />
    <button class="btn-add" bindtap="openAddDialog">+ 新增</button>
  </view>

  <!-- 分类筛选 -->
  <scroll-view scroll-x class="category-filter" enable-flex>
    <view
      wx:for="{{categories}}"
      wx:key="*this"
      class="cat-item {{activeCategory === item ? 'cat-active' : ''}}"
      data-cat="{{item}}"
      bindtap="filterByCategory"
    >{{item}} ({{categoryCount[item]}})</view>
  </scroll-view>

  <!-- 知识列表 -->
  <scroll-view scroll-y class="knowledge-list">
    <view
      wx:for="{{filteredList}}"
      wx:key="id"
      class="kb-item"
    >
      <view class="kb-item-header">
        <view class="kb-category-tag">{{item.category}}</view>
        <view class="kb-actions">
          <text class="btn-edit" data-id="{{item.id}}" bindtap="openEditDialog">编辑</text>
          <text class="btn-delete" data-id="{{item.id}}" bindtap="confirmDelete">删除</text>
        </view>
      </view>
      <view class="kb-question">{{item.question}}</view>
      <view class="kb-answer">{{item.answer}}</view>
    </view>

    <view wx:if="{{filteredList.length === 0}}" class="empty-state">
      <text>暂无匹配结果</text>
    </view>
  </scroll-view>

  <!-- 新增/编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showDialog}}" bindtap="closeDialog">
    <view class="modal-card" catchtap="">
      <view class="modal-header">
        <text>{{editingId ? '编辑' : '新增'}}知识条目</text>
        <text class="modal-close" bindtap="closeDialog">✕</text>
      </view>

      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">分类</text>
          <picker
            mode="selector"
            range="{{categories}}"
            value="{{selectedCategoryIndex}}"
            bindchange="onCategoryChange"
          >
            <view class="form-picker">
              {{categories[selectedCategoryIndex]}}
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">问题</text>
          <input
            class="form-input"
            placeholder="输入问题"
            value="{{formQuestion}}"
            bindinput="onQuestionInput"
          />
        </view>

        <view class="form-item">
          <text class="form-label">回答（分步骤）</text>
          <textarea
            class="form-textarea"
            placeholder="输入分步骤回答（每行一步）"
            value="{{formAnswer}}"
            bindinput="onAnswerInput"
          />
        </view>

        <view class="form-item">
          <text class="form-label">关键词（逗号分隔）</text>
          <input
            class="form-input"
            placeholder="如：配对,连接,蓝牙"
            value="{{formKeywords}}"
            bindinput="onKeywordsInput"
          />
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeDialog">取消</button>
        <button class="btn-save" bindtap="saveKnowledge">保存</button>
      </view>
    </view>
  </view>

  <!-- 删除确认框 -->
  <view class="modal-mask" wx:if="{{showDeleteConfirm}}">
    <view class="confirm-card">
      <text class="confirm-title">确认删除？</text>
      <text class="confirm-desc">删除后无法恢复</text>
      <view class="confirm-btns">
        <button class="btn-cancel" bindtap="cancelDelete">取消</button>
        <button class="btn-danger" bindtap="doDelete">删除</button>
      </view>
    </view>
  </view>

</view>
