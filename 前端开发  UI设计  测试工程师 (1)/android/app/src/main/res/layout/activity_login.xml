<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f7"
    android:gravity="center_horizontal"
    android:paddingHorizontal="32dp"
    android:paddingTop="80dp">

    <LinearLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_login_logo"
        android:gravity="center"
        android:layout_marginBottom="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🎧" android:textSize="36sp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp" android:textColor="#1d1d1f"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/login_title"
        android:textSize="14sp" android:textColor="#86868b"
        android:layout_marginBottom="40dp" />

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="56dp"
        android:background="@drawable/bg_input"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp" android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <EditText
            android:id="@+id/et_username"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="@string/login_username_hint"
            android:textColor="#1d1d1f" android:textColorHint="#86868b"
            android:textSize="16sp" android:inputType="text"
            android:maxLength="20" android:background="@null" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="56dp"
        android:background="@drawable/bg_input"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp" android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        <EditText
            android:id="@+id/et_password"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="@string/login_password_hint"
            android:textColor="#1d1d1f" android:textColorHint="#86868b"
            android:textSize="16sp" android:inputType="textPassword"
            android:maxLength="32" android:background="@null" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_error"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#FF3B30" android:textSize="13sp"
        android:paddingHorizontal="4dp" android:layout_marginBottom="12dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/btn_login"
        android:layout_width="match_parent" android:layout_height="50dp"
        android:background="@drawable/bg_send_btn"
        android:gravity="center"
        android:text="@string/login_btn"
        android:textColor="#ffffff" android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:orientation="vertical"
        android:visibility="gone"
        android:id="@+id/layout_register"
        android:layout_marginBottom="8dp">
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#E5E5EA" android:layout_marginBottom="16dp" android:layout_marginTop="8dp" />
        <EditText
            android:id="@+id/et_nickname"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:hint="@string/login_nickname_hint"
            android:textColor="#1d1d1f" android:textColorHint="#86868b"
            android:textSize="15sp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp" />
        <TextView
            android:id="@+id/btn_register"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:background="@drawable/bg_quick_tag"
            android:gravity="center"
            android:text="@string/login_register_btn"
            android:textColor="#0071e3" android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_toggle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/login_no_account"
        android:textColor="#0066cc" android:textSize="13sp" />

    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="24dp" android:layout_height="24dp"
        android:layout_marginTop="12dp" android:visibility="gone"
        android:indeterminateTint="#0071e3" />
</LinearLayout>
