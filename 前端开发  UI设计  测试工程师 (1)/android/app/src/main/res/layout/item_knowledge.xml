<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="#FFFFFF"
    app:cardElevation="1dp"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- 分类标签 + 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_kb_cat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:background="#E8F1FF"
                android:text="配对连接"
                android:textColor="#007AFF"
                android:textSize="11sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/btn_kb_edit"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:text="编辑"
                android:textColor="#007AFF"
                android:textSize="13sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/btn_kb_del"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:text="删除"
                android:textColor="#FF3B30"
                android:textSize="13sp"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <!-- 问题 -->
        <TextView
            android:id="@+id/tv_kb_q"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#1C1C1E"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- 回答 -->
        <TextView
            android:id="@+id/tv_kb_a"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#8E8E93"
            android:textSize="13sp"
            android:maxLines="3"
            android:ellipsize="end" />

        <!-- 关键词 -->
        <TextView
            android:id="@+id/tv_kb_kw"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="关键词: 配对,连接,蓝牙"
            android:textColor="#C6C6C8"
            android:textSize="11sp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
