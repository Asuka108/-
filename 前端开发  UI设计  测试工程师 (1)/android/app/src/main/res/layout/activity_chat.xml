<?xml version="1.0" encoding="utf-8"?>
<!-- Pineapple 风格聊天界面 — 极简主义，大面积留白 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#fbfbfd">

    <!-- 顶栏 — 毛玻璃效果用半透明背景模拟 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:background="#fafafc"
        android:elevation="0dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="#1c1c1e"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01" />

        <TextView
            android:id="@+id/btn_new_chat"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:textColor="#0066cc"
            android:textSize="14sp"
            android:text="@string/chat_new_conversation"
            android:fontFamily="sans-serif"
            android:letterSpacing="-0.01" />

        <TextView
            android:id="@+id/btn_transfer"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:textColor="#FF9500"
            android:textSize="14sp"
            android:text="转人工"
            android:fontFamily="sans-serif"
            android:letterSpacing="-0.01" />

        <TextView
            android:id="@+id/btn_exit_agent"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:textColor="#FF3B30"
            android:textSize="14sp"
            android:text="退出人工"
            android:fontFamily="sans-serif"
            android:letterSpacing="-0.01"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btn_history"
            android:layout_width="44dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:textColor="#0066cc"
            android:textSize="14sp"
            android:text="@string/chat_history"
            android:fontFamily="sans-serif"
            android:letterSpacing="-0.01" />

        <TextView
            android:id="@+id/btn_settings"
            android:layout_width="44dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:textColor="#0066cc"
            android:textSize="14sp"
            android:text="@string/chat_settings"
            android:fontFamily="sans-serif"
            android:letterSpacing="-0.01" />
    </LinearLayout>

    <!-- 消息列表 — 大面积留白 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

    <!-- 快捷问题 — 灰色底分隔 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#ffffff"
        android:scrollbars="none"
        android:paddingVertical="12dp"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tag_q1"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:paddingHorizontal="18dp"
                android:gravity="center"
                android:text="@string/quick_q1"
                android:textSize="13sp"
                android:textColor="#0071e3"
                android:background="@drawable/bg_quick_tag"
                android:layout_marginEnd="8dp"
                android:maxLines="1"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.01" />

            <TextView
                android:id="@+id/tag_q2"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:paddingHorizontal="18dp"
                android:gravity="center"
                android:text="@string/quick_q2"
                android:textSize="13sp"
                android:textColor="#0071e3"
                android:background="@drawable/bg_quick_tag"
                android:layout_marginEnd="8dp"
                android:maxLines="1"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.01" />

            <TextView
                android:id="@+id/tag_q3"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:paddingHorizontal="18dp"
                android:gravity="center"
                android:text="@string/quick_q3"
                android:textSize="13sp"
                android:textColor="#0071e3"
                android:background="@drawable/bg_quick_tag"
                android:layout_marginEnd="8dp"
                android:maxLines="1"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.01" />

            <TextView
                android:id="@+id/tag_q4"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:paddingHorizontal="18dp"
                android:gravity="center"
                android:text="@string/quick_q4"
                android:textSize="13sp"
                android:textColor="#0071e3"
                android:background="@drawable/bg_quick_tag"
                android:layout_marginEnd="8dp"
                android:maxLines="1"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.01" />

            <TextView
                android:id="@+id/tag_q5"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:paddingHorizontal="18dp"
                android:gravity="center"
                android:text="@string/quick_q5"
                android:textSize="13sp"
                android:textColor="#0071e3"
                android:background="@drawable/bg_quick_tag"
                android:maxLines="1"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.01" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- 底部输入区域 — iMessage 风格 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#fafafc"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:elevation="0dp">

        <EditText
            android:id="@+id/et_input"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:hint="@string/chat_input_hint"
            android:textColor="#1c1c1e"
            android:textColorHint="#86868b"
            android:textSize="15sp"
            android:maxLines="4"
            android:inputType="textMultiLine"
            android:imeOptions="actionSend"
            android:fontFamily="sans-serif"
            android:letterSpacing="-0.01" />

        <TextView
            android:id="@+id/btn_send"
            android:layout_width="56dp"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_send_btn"
            android:gravity="center"
            android:text="@string/chat_send"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01" />
    </LinearLayout>
</LinearLayout>
