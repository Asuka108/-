<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#007AFF"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="菠萝耳机AI客服"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_history"
            android:layout_width="48dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="历史"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- 错误提示条 -->
    <TextView
        android:id="@+id/tv_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:background="#FFF3F3"
        android:text="网络连接失败，点击重试"
        android:textColor="#FF3B30"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- 消息列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

    <!-- 快捷问题横滑栏 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:scrollbars="none"
        android:paddingVertical="10dp"
        android:paddingHorizontal="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tag_q1"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="16dp"
                android:gravity="center"
                android:text="AirPods怎么连接？"
                android:textSize="13sp"
                android:textColor="#007AFF"
                android:background="@drawable/bg_quick_tag"
                android:layout_marginEnd="8dp"
                android:maxLines="1" />

            <TextView
                android:id="@+id/tag_q2"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="16dp"
                android:gravity="center"
                android:text="左耳没声音怎么办？"
                android:textSize="13sp"
                android:textColor="#007AFF"
                android:background="@drawable/bg_quick_tag"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tag_q3"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="16dp"
                android:gravity="center"
                android:text="保修期多久？"
                android:textSize="13sp"
                android:textColor="#007AFF"
                android:background="@drawable/bg_quick_tag"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tag_q4"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="16dp"
                android:gravity="center"
                android:text="如何辨别真伪？"
                android:textSize="13sp"
                android:textColor="#007AFF"
                android:background="@drawable/bg_quick_tag"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tag_q5"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="16dp"
                android:gravity="center"
                android:text="电池不耐用怎么办？"
                android:textSize="13sp"
                android:textColor="#007AFF"
                android:background="@drawable/bg_quick_tag" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- 底部输入区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/et_input"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="16dp"
            android:hint="请输入您的问题..."
            android:textSize="15sp"
            android:maxLines="3"
            android:inputType="textMultiLine"
            android:imeOptions="actionSend" />

        <TextView
            android:id="@+id/btn_send"
            android:layout_width="56dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_send_btn"
            android:gravity="center"
            android:text="发送"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
